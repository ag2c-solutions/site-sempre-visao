---
import Logo from './Logo.astro';
const Year = new Date().getFullYear();
---
<footer class="footer bg-[#2C3C7E] text-white w-full relative">
  <div class="footer-content max-w-7xl mx-auto pt-18 px-3 md:px-12 lg:px-28 pb-45.5 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-[60px]">
    
    <!-- Column 1: Intro -->
    <div class="flex flex-col">
      <h2 class="text-[18px] font-medium text-justify leading-relaxed opacity-95">
        O grupo Sempre Sorrindo inova mais uma vez e apresenta a Sempre
        Visão, a clínica oftalmológica da sua família.
        <br /><br />
        Consultas de vista, exames especializados, cirurgia de catarata sem
        fila e muito mais.
      </h2>
    </div>

    <!-- Column 2: Links -->
    <div class="flex flex-col">
      <h2 class="text-lg font-semibold mb-6">Sempre Visão</h2>
      <nav aria-label="Links Sempre Visão">
        <ul class="flex flex-col gap-3">
          <li>
            <a href="/#About" class="text-[14px] opacity-90 hover:opacity-100 transition-opacity">A Sempre Visão</a>
          </li>
          <li>
            <a href="/#Servicos" class="text-[14px] opacity-90 hover:opacity-100 transition-opacity">Serviços</a>
          </li>
          <li>
            <a href="/#Structure" class="text-[14px] opacity-90 hover:opacity-100 transition-opacity">Estrutura</a>
          </li>
          <li>
            <a href="/#Team" class="text-[14px] opacity-90 hover:opacity-100 transition-opacity">Equipe</a>
          </li>
        </ul>
      </nav>
    </div>

    <!-- Column 3: Services -->
    <div class="flex flex-col">
      <h2 class="text-lg font-semibold mb-6">Serviços</h2>
      <nav aria-label="Links de Serviços">
        <ul class="flex flex-col gap-3">
          <li>
            <a href="https://wa.me/5516992627740" target="_blank" class="text-[14px] opacity-90 hover:opacity-100 transition-opacity">
              Consultas
            </a>
          </li>
          <li>
            <a href="/cirurgias" class="text-[14px] opacity-90 hover:opacity-100 transition-opacity">Cirurgias</a>
          </li>
          <li>
            <a href="/exames" class="text-[14px] opacity-90 hover:opacity-100 transition-opacity">Exames</a>
          </li>
          <li>
            <a href="https://semprevisao.sivoe.med.br/" target="_blank" class="text-[14px] opacity-90 hover:opacity-100 transition-opacity">
              Resultado de exames
            </a>
          </li>
        </ul>
      </nav>
    </div>

    <!-- Column 4: Contact -->
    <div class="flex flex-col">
      <h2 class="text-lg font-semibold mb-6">Contato</h2>
      <ul class="flex flex-col gap-3">
        <!-- Phone -->
        <li class="flex items-center gap-2 text-[14px] opacity-90 hover:opacity-100 transition-opacity">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-tertiary">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          <a href="tel:+551634415007" aria-label="Telefone">16 3441-5007</a>
        </li>
        <!-- WhatsApp -->
        <li class="flex items-center gap-2 text-[14px] opacity-90 hover:opacity-100 transition-opacity">
          <svg class="text-tertiary w-[18px] h-[18px] fill-current" viewBox="0 0 16 16">
            <path d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.907h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.69-4.98c-.202-.101-1.202-.594-1.387-.662-.185-.069-.32-.103-.453.1-.133.203-.518.662-.636.793-.118.131-.235.148-.437.047a5.5 5.5 0 0 1-1.625-1.003 6 6 0 0 1-1.127-1.4c-.118-.203-.013-.313.088-.413.09-.09.202-.236.3-.354.1-.118.133-.2.2-.33a.47.47 0 0 0-.024-.447c-.06-.118-.453-1.092-.62-1.492-.164-.398-.333-.344-.453-.35-.118-.006-.253-.006-.388-.006a.75.75 0 0 0-.543.254c-.185.203-.706.69-0.706 1.682s.722 1.947.823 2.08c.1.133 1.42 2.167 3.44 3.036.48.207.854.33 1.147.424.484.154.924.132 1.272.08.388-.057 1.202-.492 1.371-1.033.17-.54.17-1.005.118-1.1-.05-.1-.185-.202-.388-.303"/>
          </svg>
          <a href="https://wa.me/5516992627740" target="_blank">16 99262-7740</a>
        </li>
        <!-- Address 1 -->
        <li class="flex items-start gap-2 text-[14px] opacity-90">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-tertiary shrink-0 mt-0.5">
            <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          <address class="not-italic leading-relaxed">
            R. São Sebastião, 614 - Centro, Ribeirão Preto - SP, 14015-040
          </address>
        </li>
        <!-- Address 2 -->
        <li class="flex items-start gap-2 text-[14px] opacity-90">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-tertiary shrink-0 mt-0.5">
            <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          <address class="not-italic leading-relaxed">
            R. Gen. Telles, 1259 - Centro, Franca - SP, 14405-090
          </address>
        </li>
      </ul>
    </div>

  </div>

  <!-- Floating White Bottom Card -->
  <div class="footer-bottom bg-white px-6 md:px-12 absolute bottom-8 left-3 md:left-12 lg:left-[112px] h-[100px] rounded-[10px] w-[calc(100%-24px)] md:w-[calc(100%-96px)] lg:w-[calc(100%-224px)] flex items-center justify-center shadow-lg">
    <div class="w-full flex justify-between items-center gap-4">
      <Logo />
      <p class="copyright text-[#2C3C7E] text-[14px] text-center font-medium">
        © {Year} Sempre Visão. Todos os direitos reservados.
      </p>
      <span class="hidden md:inline-block w-[150px]"></span> <!-- Spacer to balance layout -->
    </div>
  </div>
</footer>
