---
<nav class="navigation relative flex gap-3 items-center justify-center h-full bg-transparent">
  <!-- Checkbox for Mobile Toggle -->
  <label class="absolute right-3 top-[calc(50%-15px)] lg:hidden cursor-pointer z-20">
    <input type="checkbox" name="mobile-btn" id="mobile__btn" class="peer hidden" />
    <!-- Hamburger Icon (CSS Drawn) -->
    <div class="hamburger w-[30px] h-[4px] bg-primary rounded-full relative transition-all duration-300
      before:content-[''] before:block before:w-[30px] before:h-[4px] before:before:h-[4px] before:bg-primary before:rounded-full before:absolute before:-top-2 before:transition-all before:duration-300
      after:content-[''] after:block after:w-[30px] after:h-[4px] after:bg-primary after:rounded-full after:absolute after:top-2 after:transition-all after:duration-300">
    </div>
  </label>

  <!-- Navigation Links -->
  <ul class="nav-links hidden lg:flex flex-col lg:flex-row items-center justify-center gap-4 lg:gap-4 text-primary bg-white lg:bg-transparent rounded-lg p-6 lg:px-[14px] lg:py-0 lg:h-full absolute lg:static top-[80px] right-3 left-3 shadow-lg lg:shadow-none z-10 border border-gray-100 lg:border-none">
    <li>
      <a href="/" class="text-[16px] lg:text-[18px] font-semibold hover:opacity-80 transition-opacity">Home</a>
    </li>
    <li>
      <a href="/cirurgias" class="text-[16px] lg:text-[18px] font-semibold hover:opacity-80 transition-opacity">Cirurgias</a>
    </li>
    <li>
      <a href="/exames" class="text-[16px] lg:text-[18px] font-semibold hover:opacity-80 transition-opacity">Exames</a>
    </li>
    <li>
      <a href="/#Team" class="text-[16px] lg:text-[18px] font-semibold hover:opacity-80 transition-opacity">Equipe</a>
    </li>
    <li>
      <a href="/#Clinics" class="text-[16px] lg:text-[18px] font-semibold hover:opacity-80 transition-opacity">Clínicas</a>
    </li>
    <li>
      <a href="/blog" class="text-[16px] lg:text-[18px] font-semibold hover:opacity-80 transition-opacity">Blog</a>
    </li>
    <li class="mt-2 lg:mt-0">
      <a href="https://semprevisao.sivoe.med.br/" target="_blank" class="inline-flex items-center justify-center text-[16px] lg:text-[18px] font-semibold bg-tertiary text-primary px-5 py-2 rounded-[5px] hover:brightness-95 transition-all whitespace-nowrap">
        Resultado de Exames
      </a>
    </li>
  </ul>
</nav>

<style>
  /* Encapsulated styling for mobile checkbox toggle */
  label:has(input:checked) .hamburger {
    background-color: transparent;
  }
  
  label:has(input:checked) .hamburger::before {
    transform: rotate(135deg);
    top: 0;
  }
  
  label:has(input:checked) .hamburger::after {
    transform: rotate(-135deg);
    top: 0;
  }
  
  /* Toggle the menu on mobile */
  label:has(input:checked) ~ ul {
    display: flex !important;
    animation: slide-in-top 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  }

  @keyframes slide-in-top {
    0% {
      transform: translateY(-20px);
      opacity: 0;
    }
    100% {
      transform: translateY(0);
      opacity: 1;
    }
  }
  
  @media (min-width: 1024px) {
    /* Ensure the menu is always flex on desktop */
    ul {
      display: flex !important;
    }
  }
</style>
