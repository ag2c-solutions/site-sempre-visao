---
// Banner images in the same order as the original: image3, image1, image2
const images = [
  { src: '/Banner-Site-Sempre-Visão_03Prancheta-1.png', alt: 'Banner Sempre Visão 3' },
  { src: '/Banner-Site-Sempre-Visão_01Prancheta-1.png', alt: 'Banner Sempre Visão 1' },
  { src: '/Banner-Site-Sempre-Visão_02Prancheta-1.png', alt: 'Banner Sempre Visão 2' },
];
---

<div id="CarouselBanner" class="banner-carousel">
  <figure class="banner-figure">
    {images.map((img, index) => (
      <img
        src={img.src}
        alt={img.alt}
        class={`banner-img${index === 0 ? ' current' : ''}`}
        data-index={index}
        width="1200"
        height="600"
        loading={index === 0 ? 'eager' : 'lazy'}
      />
    ))}
  </figure>
</div>

<style>
  .banner-carousel {
    width: 100%;
    margin: 0 auto;
    text-align: center;
    padding: 0px 12px 12px 12px;
  }

  .banner-figure {
    height: 35vh;
    position: relative;
    width: 100%;
    border-radius: 10px;
    overflow: hidden;
    display: block;
  }

  .banner-img {
    max-width: 100%;
    border-radius: 10px;
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.5s ease-in-out;
  }

  .banner-img.current {
    opacity: 1;
  }

  .banner-img.fade-out {
    opacity: 0;
  }

  @media screen and (min-width: 720px) {
    .banner-carousel {
      padding: 0px 24px 12px 24px;
    }
  }

  @media screen and (min-width: 1024px) {
    .banner-carousel {
      padding: 0px 52px 12px 52px;
    }

    .banner-figure {
      height: calc(100dvh - 150px);
    }
  }
</style>

<script>
  function initCarouselBanner() {
    const imgs = document.querySelectorAll<HTMLImageElement>('#CarouselBanner .banner-img');
    if (!imgs.length) return;

    let currentIndex = 0;
    const total = imgs.length;

    setInterval(() => {
      // Fade out current
      imgs[currentIndex].classList.add('fade-out');
      imgs[currentIndex].classList.remove('current');

      // Advance index
      currentIndex = (currentIndex + 1) % total;

      // Fade in next after a brief tick so CSS transition runs
      setTimeout(() => {
        imgs.forEach((img, i) => {
          img.classList.toggle('current', i === currentIndex);
          img.classList.remove('fade-out');
        });
      }, 520); // slightly after transition duration (500ms)
    }, 5000);
  }

  initCarouselBanner();
  document.addEventListener('astro:page-load', initCarouselBanner);
</script>
