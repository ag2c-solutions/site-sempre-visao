---
---
<section id="HeroSection" class="w-full max-w-[1200px] mx-auto px-3 md:px-[60px] min-h-[623px] h-[calc(100vh-150px)]">
  <section class="w-full min-h-full rounded-[10px] bg-gradient-to-r from-[#1F2D60] via-[#344275] to-[#1F2D60] p-6 md:p-[90px_52px_12px_52px] text-white flex flex-col md:flex-row justify-between gap-12 md:gap-6">
    
    <!-- Left Column: Content -->
    <article class="max-w-[650px] flex flex-col gap-3 p-2 justify-center">
      <span class="h-[60px] w-[160px] flex items-center justify-center bg-white/20 border-l-4 border-white rounded-[5px] text-[20px] font-semibold">
        Sempre Visão
      </span>
      <h1 class="text-[32px] md:text-[42px] font-semibold leading-tight">
        Cuida de você e quem você ama.
      </h1>
      <p class="text-[18px] md:text-[24px] font-semibold text-white/70 leading-normal">
        Cuide da sua visão com a Sempre Visão! Oferecemos prevenção,
        diagnóstico e tratamento para a saúde dos seus olhos
      </p>

      <ul class="flex flex-col sm:flex-row gap-4 py-[22px] border-b border-white/20">
        <li class="flex items-center">
          <a href="https://wa.me/5516992627740" target="_blank" class="w-full sm:w-[350px] py-[14px] text-center font-semibold text-[18px] bg-white text-[#1F2D60] rounded-lg hover:brightness-95 transition-all duration-300 shadow-md">
            Agende sua consulta hoje mesmo!
          </a>
        </li>
        <li class="flex items-center">
          <a href="#Clinics" class="flex items-center gap-3 font-semibold text-[18px] hover:text-white/80 transition-colors">
            <div class="h-[55px] w-[55px] rounded-full bg-tertiary flex items-center justify-center text-primary relative transition-transform hover:scale-105 duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" viewBox="0 0 24 24" class="text-primary mt-0.5 ml-0.5">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </div>
            Nosso consultório
          </a>
        </li>
      </ul>
    </article>

    <!-- Right Column: Stats -->
    <div class="flex flex-row md:flex-col gap-4 justify-center md:justify-end items-center md:items-end w-full md:w-auto mt-4 md:mt-0">
      <!-- Sat 1 -->
      <article class="w-[160px] md:w-[225px] h-[110px] md:h-[138px] rounded-[30px] md:rounded-[40px] rounded-tl-[50px] md:rounded-tl-[75px] rounded-bl-none bg-primary flex flex-col justify-center items-center gap-1 shadow-lg">
        <h4 class="text-[20px] md:text-[22px] font-semibold text-white">+ 20mil</h4>
        <p class="text-[14px] md:text-[18px] text-white/80">clientes satisfeitos</p>
      </article>
      <!-- Stat 2 -->
      <article class="w-[160px] md:w-[225px] h-[110px] md:h-[138px] rounded-[30px] md:rounded-[40px] rounded-tl-none rounded-bl-[50px] md:rounded-bl-[75px] border border-white/25 bg-transparent flex flex-col justify-center items-center gap-1 shadow-md">
        <h4 class="text-[20px] md:text-[22px] font-semibold text-white">93+</h4>
        <p class="text-[14px] md:text-[18px] text-white/80">profissionais</p>
      </article>
    </div>

  </section>
</section>
