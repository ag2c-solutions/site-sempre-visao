---
const clinics = [
  {
    name: 'Ribeirão Preto',
    mapUrl: 'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3720.3889835110617!2d-47.81197022462438!3d-21.176701178339215!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x94b9befbeac0a8d9%3A0x8d14b439914bd93a!2sR.%20São%20Sebastião%2C%20614%20-%20Centro%2C%20Ribeirão%20Preto%20-%20SP%2C%2014015-040!5e0!3m2!1spt-BR!2sbr!4v1741891813471!5m2!1spt-BR!2sbr'
  },
  {
    name: 'Franca',
    mapUrl: 'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3736.2463573572704!2d-47.40599312445423!3d-20.53709868099205!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x94b0a631beb40a59%3A0xf12b89598f2c7167!2sR.%20Gen.%20Telles%2C%201259%20-%20Centro%2C%20Franca%20-%20SP%2C%2014405-090!5e0!3m2!1spt-BR!2sbr!4v1760361899763!5m2!1spt-BR!2sbr'
  }
];
---
<section id="Clinics" class="w-full max-w-[1200px] mx-auto py-12 px-3 md:px-[72px] lg:px-[110px] flex flex-col items-center justify-center gap-6 min-h-[600px]">
  <div>
    <h2 class="text-[36px] lg:text-[48px] text-primary font-semibold text-center">Nossas Clínicas</h2>
  </div>

  <section class="flex flex-col md:flex-row w-full gap-3 md:gap-6">
    <ul class="flex flex-row md:flex-col gap-3 md:gap-6 w-full md:w-[25%] shrink-0">
      {clinics.map((clinic, index) => (
        <li
          data-map-url={clinic.mapUrl}
          data-tab-index={index}
          class={`clinic-tab cursor-pointer font-bold text-primary px-3 py-2 rounded-[4px] border border-transparent transition-all duration-300 ${index === 0 ? 'bg-primary text-white' : 'hover:bg-gray-100'}`}
        >
          {clinic.name}
        </li>
      ))}
    </ul>
    
    <iframe
      id="clinic-map-iframe"
      src={clinics[0].mapUrl}
      class="w-full md:w-[75%] h-[450px] rounded-[10px] border-0 shadow-sm"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
    ></iframe>
  </section>
</section>

<script>
  function initClinicMapTabs() {
    const tabs = document.querySelectorAll('.clinic-tab');
    const iframe = document.getElementById('clinic-map-iframe') as HTMLIFrameElement;

    if (!tabs.length || !iframe) return;

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        // Reset all tabs
        tabs.forEach((t) => {
          t.className = 'clinic-tab cursor-pointer font-bold text-primary px-3 py-2 rounded-[4px] border border-transparent transition-all duration-300 hover:bg-gray-100';
        });

        // Activate clicked tab
        tab.className = 'clinic-tab cursor-pointer font-bold text-primary px-3 py-2 rounded-[4px] border border-transparent transition-all duration-300 bg-primary text-white';

        // Update map iframe source
        const mapUrl = tab.getAttribute('data-map-url');
        if (mapUrl) {
          iframe.src = mapUrl;
        }
      });
    });
  }

  // Initialize
  initClinicMapTabs();
  document.addEventListener('astro:page-load', initClinicMapTabs);
</script>
