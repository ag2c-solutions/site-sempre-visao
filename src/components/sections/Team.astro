---
const team = [
  {
    name: 'Dr. Breno Reis Almeida',
    crm: '180.109',
    imageUrl: encodeURI('/WhatsApp Image 2025-03-13 at 17.42.56.jpg')
  },
  {
    name: 'Dra. Camila Cardoso S. B. Alcântara',
    crm: '174.084',
    imageUrl: encodeURI('/WhatsApp Image 2025-03-13 at 14.50.26.jpeg')
  },
  {
    name: 'Dr. Gabriel Ricci Pupo',
    crm: '223.337',
    imageUrl: encodeURI('/WhatsApp Image 2025-03-16 at 08.41.12_d5476c23.jpg')
  }
];
---
<section id="Team" class="w-full max-w-[1200px] mx-auto py-12 px-3 md:px-[72px] lg:px-[110px] flex flex-col items-center justify-center gap-9 min-h-[600px]">
  <div>
    <h2 class="text-[36px] lg:text-[48px] text-primary font-semibold text-center">Conheça o nosso corpo clínico</h2>
  </div>

  <ul class="flex sm:grid sm:grid-cols-2 lg:grid-cols-3 gap-8 overflow-x-auto sm:overflow-visible scrollbar-none py-4 px-2 w-full justify-start sm:justify-center snap-x snap-mandatory">
    {team.map((member) => (
      <li class="shrink-0 sm:shrink snap-center w-[280px] sm:w-full max-w-[350px] mx-auto">
        <figure class="relative w-full h-[400px] rounded-t-[20px] bg-primary/50 overflow-hidden shadow-md hover:shadow-lg transition-shadow duration-300">
          <img 
            src={member.imageUrl} 
            alt={`Dr(a) ${member.name}`} 
            class="absolute inset-0 w-full h-full object-cover"
            loading="lazy"
          />
          <figcaption class="absolute bottom-4 left-[5%] w-[90%] h-[90px] bg-white/80 backdrop-blur-[4px] flex flex-col items-center justify-center p-3 rounded-[10px] text-primary font-bold text-center">
            <h4 class="text-[16px] leading-snug">{member.name}</h4>
            <p class="text-[13px] font-semibold text-secondary mt-1">CRM: {member.crm}</p>
          </figcaption>
        </figure>
      </li>
    ))}
  </ul>
</section>

<style>
  /* Hide scrollbar utility for team list */
  .scrollbar-none::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-none {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
