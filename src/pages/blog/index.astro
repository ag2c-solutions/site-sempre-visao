---
import Layout from '../../layouts/Layout.astro';
import { posts } from '../../data/posts';
import type { IPost } from '../../data/post.interface';

const defaultImage = "/images/placeholder.svg";

function getImageUrl(imageUrl: string | undefined) {
  return imageUrl
    ? `https://backup.clinicassempresorrindo.com.br/storage/app/uploads/${imageUrl}`
    : defaultImage;
}

function getSortedPosts(allPosts: IPost[]) {
  return [...allPosts].sort((a, b) => (b.date || '').localeCompare(a.date || ''));
}

const sortedPosts = getSortedPosts(posts);
const heroPost = sortedPosts[0]; // Set the first post as the highlighted hero post
const mostReadPosts = sortedPosts.slice(0, 6); // Simulating popular posts
const gridPosts = sortedPosts.slice(6); // The rest of the posts
---

<Layout title="Blog | Sempre Visão" description="Acompanhe as últimas notícias, dicas de especialistas e novidades sobre oftalmologia e saúde dos olhos no Blog Sempre Visão.">
  <div class="w-full max-w-7xl mx-auto px-4 py-12 bg-gradient-to-br from-blue-50 via-white to-slate-100 min-h-screen">
    
    <header class="flex flex-col items-center mb-14">
      <div class="mb-4 flex items-center gap-3">
        <span class="inline-block w-12 h-12 rounded-full bg-gradient-to-tr from-blue-600 to-cyan-400 flex items-center justify-center shadow-lg">
          <svg width="28" height="28" fill="none" viewBox="0 0 24 24" class="text-white">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z" fill="currentColor"/>
          </svg>
        </span>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-slate-800 tracking-tight drop-shadow-sm">Blog Sempre Visão</h1>
      </div>
      <p class="text-slate-500 text-lg font-medium max-w-2xl text-center">
        Descubra novidades, dicas e conteúdos exclusivos sobre saúde ocular, bem-estar e tecnologia em oftalmologia.
      </p>
    </header>

    <!-- HERO POST -->
    {heroPost && (
      <section class="mb-16">
        <a href={`/blog/${heroPost.slug}`} class="block group rounded-3xl overflow-hidden shadow-2xl border border-blue-100 bg-white hover:shadow-blue-200 transition-all duration-200">
          <div class="relative w-full aspect-[2/1] bg-gradient-to-tr from-blue-100 to-slate-200">
            <img
              src={getImageUrl(heroPost.imageUrl)}
              alt={heroPost.title}
              class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300"
            />
            {heroPost.date && (
              <span class="absolute top-4 left-4 bg-white/80 text-slate-700 text-xs font-semibold px-3 py-1 rounded-full shadow-sm backdrop-blur-sm">
                {new Date(heroPost.date).toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' })}
              </span>
            )}
          </div>
          <div class="p-8 pb-6 flex flex-col gap-2">
            <div class="flex flex-wrap gap-2 mb-1">
              {heroPost.tags?.map(tag => (
                <span class="bg-blue-100 text-blue-700 text-xs font-semibold px-2 py-1 rounded-full">{tag}</span>
              ))}
            </div>
            <h2 class="text-3xl font-extrabold text-slate-800 mb-2 group-hover:text-blue-700 transition-colors leading-tight">
              {heroPost.title}
            </h2>
            <p class="text-slate-600 text-lg mb-3 line-clamp-3 leading-relaxed">{heroPost.description}</p>
            <span class="inline-block mt-2 text-blue-700 font-semibold group-hover:underline">Ler matéria completa →</span>
          </div>
        </a>
      </section>
    )}

    <!-- MAIS LIDAS -->
    <aside class="mb-14">
      <h2 class="text-2xl font-bold text-slate-800 mb-6 border-b border-gray-100 pb-2">Mais Lidas</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {mostReadPosts.map(post => (
          <article class="group bg-gradient-to-br from-blue-50 to-cyan-100 rounded-2xl border border-blue-100 shadow flex flex-col overflow-hidden transition-all duration-200 hover:scale-[1.02] hover:shadow-xl hover:border-blue-300">
            <a href={`/blog/${post.slug}`} class="block w-full aspect-[16/9] bg-gradient-to-tr from-blue-100 to-slate-200 relative overflow-hidden">
              <img
                src={getImageUrl(post.imageUrl)}
                alt={post.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              />
            </a>
            <div class="p-5 flex flex-col flex-1 gap-2">
              <h3 class="text-lg font-bold text-blue-800 mb-1 leading-snug">
                <a href={`/blog/${post.slug}`} class="hover:text-blue-600 transition-colors">
                  {post.title}
                </a>
              </h3>
              <p class="text-slate-600 text-sm mb-3 flex-1 line-clamp-2 leading-relaxed">{post.description}</p>
              <a
                href={`/blog/${post.slug}`}
                class="mt-auto inline-block text-blue-700 font-semibold hover:text-blue-900 transition-colors"
              >
                Ler mais
              </a>
            </div>
          </article>
        ))}
      </div>
    </aside>

    <!-- GRID DE POSTS RECENTES -->
    {gridPosts.length > 0 && (
      <section class="mb-20">
        <h2 class="text-2xl font-bold text-slate-800 mb-6 border-b border-gray-100 pb-2">Últimas do Blog</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-10">
          {gridPosts.map(post => (
            <article class="group bg-white rounded-2xl border border-slate-200 shadow-lg flex flex-col overflow-hidden transition-all duration-200 hover:scale-[1.025] hover:shadow-2xl hover:border-blue-200">
              <a href={`/blog/${post.slug}`} class="block w-full aspect-[16/9] bg-gradient-to-tr from-blue-100 to-slate-200 relative overflow-hidden">
                <img
                  src={getImageUrl(post.imageUrl)}
                  alt={post.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                />
                {post.date && (
                  <span class="absolute top-3 left-3 bg-white/80 text-slate-700 text-xs font-semibold px-3 py-1 rounded-full shadow-sm backdrop-blur-sm">
                    {new Date(post.date).toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' })}
                  </span>
                )}
              </a>
              <div class="p-6 flex flex-col flex-1 gap-2">
                <div class="flex flex-wrap gap-2 mb-1">
                  {post.tags?.map(tag => (
                    <span class="bg-blue-100 text-blue-700 text-xs font-semibold px-2 py-1 rounded-full">{tag}</span>
                  ))}
                </div>
                <h3 class="text-xl font-bold text-slate-800 mb-2 leading-tight">
                  <a href={`/blog/${post.slug}`} class="hover:text-blue-700 transition-colors">
                    {post.title}
                  </a>
                </h3>
                <p class="text-slate-600 text-base mb-5 flex-1 line-clamp-3 leading-relaxed">{post.description}</p>
                <a
                  href={`/blog/${post.slug}`}
                  class="mt-auto inline-block text-blue-700 font-semibold hover:text-blue-900 transition-colors"
                >
                  Ler mais
                </a>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

  </div>
</Layout>
