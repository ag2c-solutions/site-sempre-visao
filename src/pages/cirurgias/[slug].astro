---
import Layout from '../../layouts/Layout.astro';
import { surgeries } from '../../data/surgeries';
import { shuffle } from '../../lib/utils';

export async function getStaticPaths() {
  return surgeries.map((surgery) => ({
    params: { slug: surgery.slug },
    props: { surgery }
  }));
}

const { surgery } = Astro.props;

// Filter 4 other surgeries to show at the bottom
function getMoreSurgeries(currentSlug: string) {
  const filtered = surgeries.filter((s) => s.slug !== currentSlug);
  const shuffled = shuffle(filtered);
  return shuffled.slice(0, 4);
}

const moreSurgeries = getMoreSurgeries(surgery.slug);
const defaultImage = "/images/placeholder.svg";
---

<Layout title={`${surgery.label} | Sempre Visão`} description={surgery.description}>
  <section id="ExamPage" class="w-full max-w-[1200px] mx-auto px-3 md:px-[52px] pb-[72px] text-secondary">
    
    <!-- Top Image banner -->
    <figure class="relative w-full h-[35vh] lg:h-[calc(100vh-150px)] rounded-[10px] overflow-hidden mt-4 shadow-sm">
      <img
        src={surgery.imageUrl ? surgery.imageUrl : defaultImage}
        alt={surgery.title}
        class="absolute inset-0 w-full h-full object-cover rounded-xl"
        loading="eager"
      />
    </figure>

    <!-- Rich Body Content -->
    <article class="exam-prose w-full min-h-[600px] py-6 md:py-12 flex flex-col justify-center items-start gap-4">
      <Fragment set:html={surgery.content} />
    </article>

    <!-- More surgeries recommendation grid -->
    <section id="MoreExams" class="w-full border-t border-gray-100 pt-12 mt-12">
      <h2 class="text-[24px] lg:text-[48px] font-bold mb-6 text-primary leading-tight">Mais Cirurgias:</h2>
      <ul class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 py-6">
        {moreSurgeries.map((item) => {
          return (
            <li class="p-[4px_12px_24px] rounded-[5px] shadow-[0_0_3px_1px_rgba(0,0,0,0.2)] hover:shadow-md transition-shadow duration-300 bg-white">
              <a href={`/cirurgias/${item.slug}`} class="flex flex-col gap-2 h-full justify-between">
                <article class="flex flex-col gap-2">
                  <h3 class="text-[18px] font-bold min-h-[60px] pt-2 text-primary leading-tight">{item.label}</h3>
                  <p class="line-clamp-6 text-[14px] font-normal text-gray-600 leading-relaxed">{item.description}</p>
                </article>
              </a>
            </li>
          );
        })}
      </ul>
    </section>

  </section>
</Layout>

<style is:global>
  @reference "../../styles/global.css";

  /* Global styling for rich HTML content injected dynamically */
  .exam-prose h1 {
    @apply text-[26px] font-bold text-primary mb-3 text-start leading-tight;
  }
  .exam-prose h2 {
    @apply text-[22px] font-bold text-primary mt-6 mb-2 text-start leading-tight;
  }
  .exam-prose p {
    @apply text-[16px] text-gray-700 leading-relaxed mt-3;
  }
  .exam-prose ul {
    @apply pl-6 my-4 list-disc flex flex-col gap-2 w-full;
  }
  .exam-prose li {
    @apply text-[16px] text-gray-700 leading-relaxed;
  }
  .exam-prose details.faq-item {
    @apply w-full border border-gray-200 rounded-[5px] mb-[10px] bg-white transition-all overflow-hidden;
  }
  .exam-prose details.faq-item summary {
    @apply font-bold text-[16px] p-[15px] cursor-pointer hover:bg-gray-50 flex justify-between items-center list-none select-none;
  }
  .exam-prose details.faq-item summary::after {
    content: '+';
    @apply float-right font-normal text-sky-600 text-xl leading-none ml-2;
  }
  .exam-prose details.faq-item[open] summary::after {
    content: '−';
  }
  .exam-prose details.faq-item p {
    @apply p-[15px] border-t border-gray-100 bg-gray-50/50 mt-0;
  }
  .exam-prose a.cta-button {
    @apply block w-fit mx-auto px-6 py-3 bg-green-600 hover:bg-green-700 text-white font-bold text-[16px] text-center rounded-[5px] mt-6 transition-all shadow-sm;
  }

  @media (min-width: 1024px) {
    .exam-prose h1 {
      @apply text-[42px];
    }
    .exam-prose h2 {
      @apply text-[30px];
    }
    .exam-prose p {
      @apply text-[18px];
    }
    .exam-prose li {
      @apply text-[18px];
    }
    .exam-prose details.faq-item summary {
      @apply text-[18px];
    }
    .exam-prose a.cta-button {
      @apply text-lg;
    }
  }
</style>
